@model GT7TuningShare.Module.ViewModels.MyActivityViewModel
@{
    Layout = null;

    const string CommentImagePattern = @"(/media/comments/[a-z0-9]+\.(png|jpg|jpeg|gif|webp))";

    string StripCommentImages(string body)
    {
        var encoded = System.Text.Encodings.Web.HtmlEncoder.Default.Encode(body ?? "");
        var stripped = System.Text.RegularExpressions.Regex.Replace(
            encoded,
            CommentImagePattern,
            "",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        // Collapse runs of whitespace introduced by the removal.
        stripped = System.Text.RegularExpressions.Regex.Replace(stripped, @"[ \t]+", " ");
        return stripped.Trim();
    }

    int CountCommentImages(string body)
    {
        if (string.IsNullOrEmpty(body)) return 0;
        return System.Text.RegularExpressions.Regex.Matches(
            body,
            CommentImagePattern,
            System.Text.RegularExpressions.RegexOptions.IgnoreCase).Count;
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Activity — GT7 Tuning Share</title>
<style>
    :root {
        --bg-app: #1a1d22;
        --bg-panel: #2a2e35;
        --bg-input: #14171b;
        --bg-input-hover: #1c2025;
        --border: #3a3f47;
        --text: #e6e8eb;
        --text-dim: #9aa0a8;
        --text-faint: #6b7079;
        --accent: #4a90e2;
        --gold: #f4c430;
        --divider: #383d44;
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; min-height: 100%; background: var(--bg-app); }
    body { font-family: "Helvetica Neue", Helvetica, Arial, sans-serif; font-size: 13px; color: var(--text); -webkit-font-smoothing: antialiased; }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    .gt7-topbar { background: var(--bg-panel); border-bottom: 1px solid var(--divider); padding: 14px 24px; display: flex; align-items: center; justify-content: space-between; }
    .gt7-brand { font-size: 16px; font-weight: 600; color: #fff; letter-spacing: .3px; }
    .gt7-brand small { font-weight: 400; color: var(--text-dim); margin-left: 8px; }
    .gt7-user-mini { font-size: 12px; color: var(--text-dim); }
    .gt7-user-mini b { color: #fff; }
    .gt7-user-mini a { color: var(--accent); }

    .gt7-page { max-width: 1280px; margin: 0 auto; padding: 16px 24px 40px; }

    .gt7-section-title {
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: .15em;
        color: var(--text-dim);
        font-weight: 600;
        padding: 6px 0;
        border-bottom: 1px solid var(--divider);
        margin: 24px 0 10px;
        display: flex;
        justify-content: space-between;
        align-items: baseline;
    }
    .gt7-section-title:first-of-type { margin-top: 8px; }
    .gt7-section-title .badge { color: var(--text-faint); font-size: 11px; font-weight: normal; }

    .gt7-card { background: var(--bg-panel); border: 1px solid var(--border); border-radius: 5px; padding: 12px 16px; margin-bottom: 8px; transition: border-color .12s, background .12s; display: flex; align-items: center; gap: 12px; }
    .gt7-card:hover { border-color: var(--accent); background: var(--bg-input-hover); }
    .gt7-card-link { flex: 1; display: flex; align-items: center; gap: 16px; text-decoration: none; color: inherit; min-width: 0; }
    .gt7-card-link:hover { text-decoration: none; color: inherit; }
    .gt7-card-row { display: flex; justify-content: space-between; align-items: center; gap: 16px; flex: 1; min-width: 0; }
    .gt7-card-delete-form { flex-shrink: 0; }
    .gt7-card-delete {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text-faint);
        padding: 6px 10px;
        border-radius: 3px;
        font-size: 11px;
        cursor: pointer;
        font-family: inherit;
        transition: color .12s, border-color .12s, background .12s;
    }
    .gt7-card-delete:hover { color: #e07c7c; border-color: #e07c7c; background: rgba(224, 124, 124, .08); }

    /* Comment cards (per-comment, one-per-row) */
    .gt7-comment-card {
        position: relative;
        background: var(--bg-panel);
        border: 1px solid var(--border);
        border-radius: 5px;
        padding: 12px 16px;
        margin-bottom: 8px;
        transition: border-color .12s, background .12s;
    }
    .gt7-comment-card:hover { border-color: var(--accent); background: var(--bg-input-hover); }
    /* Make the whole card clickable by stretching the head's link via a pseudo overlay. */
    .gt7-comment-card-head a::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 5px;
    }
    /* Keep the Delete button above the overlay so it remains clickable. */
    .gt7-comment-card .gt7-card-delete-form { position: relative; z-index: 2; }
    .gt7-comment-card-head {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 10px;
        padding-bottom: 10px;
        border-bottom: 1px solid var(--divider);
    }
    .gt7-comment-card-head a { display: flex; align-items: center; gap: 12px; flex: 1; min-width: 0; text-decoration: none; color: inherit; }
    .gt7-comment-card-head a:hover .gt7-card-name { color: var(--accent); }
    .gt7-comment-card-body {
        color: var(--text);
        font-size: 13px;
        line-height: 1.5;
        white-space: pre-wrap;
        word-break: break-word;
        margin: 0;
    }
    .gt7-comment-card-date { color: var(--text-faint); font-size: 11px; margin-top: 8px; }
    .gt7-comment-image-badge {
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 6px 10px;
        border-radius: 3px;
        border: 1px solid var(--border);
        background: transparent;
        color: var(--text-dim);
        font-size: 11px;
        line-height: 1;
    }
    .gt7-comment-image-badge svg { width: 11px; height: 11px; flex-shrink: 0; display: block; }
    .gt7-card-thumb { width: 90px; height: 52px; flex-shrink: 0; border-radius: 3px; background: linear-gradient(135deg, #1f2329 0%, #2c3138 100%); display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .gt7-card-thumb img { max-width: 100%; max-height: 100%; object-fit: contain; }
    .gt7-card-body { flex: 1; min-width: 0; }
    .gt7-card-name { font-size: 14px; font-weight: 600; color: #fff; margin: 0 0 3px; }
    .gt7-card-car { color: var(--text-dim); font-size: 12px; }
    .gt7-card-meta { color: var(--text-faint); font-size: 11px; text-align: right; line-height: 1.5; flex-shrink: 0; }
    .gt7-card-meta b { color: var(--text-dim); font-weight: 500; }
    .gt7-card-stars { color: var(--gold); font-size: 14px; letter-spacing: 1px; flex-shrink: 0; }

    .gt7-empty { background: var(--bg-panel); border: 1px dashed var(--border); border-radius: 5px; padding: 24px; text-align: center; color: var(--text-dim); font-size: 12px; }

    .gt7-tabs {
        display: flex;
        gap: 6px;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }
    .gt7-tab {
        background: var(--bg-panel);
        border: 1px solid var(--border);
        color: var(--text-dim);
        padding: 8px 16px;
        border-radius: 4px;
        font-size: 12px;
        text-decoration: none;
        transition: border-color .12s, color .12s, background .12s;
    }
    .gt7-tab:hover { color: #fff; border-color: var(--accent); text-decoration: none; }
    .gt7-tab.active {
        background: var(--accent);
        border-color: var(--accent);
        color: #fff;
    }
    .gt7-tab .count {
        display: inline-block;
        margin-left: 6px;
        padding: 1px 7px;
        background: rgba(0,0,0,.25);
        border-radius: 999px;
        font-size: 10px;
        font-weight: 600;
    }

    @@media (max-width: 768px) { .gt7-card-row { flex-direction: column; gap: 8px; } .gt7-card-meta { text-align: left; } }
</style>
</head>
<body>

<div class="gt7-topbar">
    <a href="/" style="text-decoration:none;color:inherit"><span class="gt7-brand">GT7 Tuning Share <small>My Activity</small></span></a>
    <span class="gt7-user-mini">
        Signed in as <b>@Model.UserName</b>
        &nbsp;·&nbsp;
        <a href="/">Browse setups</a>
    </span>
</div>

<div class="gt7-page">

    <div class="gt7-tabs">
        <a class="gt7-tab @(Model.ActiveView == "all" ? "active" : "")" asp-action="MyActivity">All</a>
        <a class="gt7-tab @(Model.ActiveView == "created" ? "active" : "")" asp-action="MyActivity" asp-route-view="created">Created<span class="count">@Model.Created.Count</span></a>
        <a class="gt7-tab @(Model.ActiveView == "rated" ? "active" : "")" asp-action="MyActivity" asp-route-view="rated">Rated<span class="count">@Model.Rated.Count</span></a>
        <a class="gt7-tab @(Model.ActiveView == "commented" ? "active" : "")" asp-action="MyActivity" asp-route-view="commented">Commented<span class="count">@Model.Commented.Count</span></a>
    </div>

    @* === Created === *@
    @if (Model.ActiveView == "all" || Model.ActiveView == "created")
    {
    <div class="gt7-section-title">
        <span>Setups I've created</span>
        <span class="badge">@Model.Created.Count</span>
    </div>
    @if (Model.Created.Count == 0)
    {
        <div class="gt7-empty">You haven't published any setups yet. <a asp-action="Create">Create your first one</a>.</div>
    }
    else
    {
        @foreach (var s in Model.Created)
        {
            <div class="gt7-card">
                <a class="gt7-card-link" asp-action="Details" asp-route-contentItemId="@s.ContentItemId">
                    <div class="gt7-card-row">
                        <div class="gt7-card-thumb">
                            @if (s.CarGameId > 0)
                            {
                                <img src="~/GT7TuningShare.Module/car_thumbnails/car@(s.CarGameId).png" alt="" onerror="this.style.display='none'" />
                            }
                        </div>
                        <div class="gt7-card-body">
                            <h2 class="gt7-card-name">@s.Title</h2>
                            <div class="gt7-card-car">@s.CarDisplayText</div>
                        </div>
                        <div class="gt7-card-meta">
                            <div><b>@(s.CreatedUtc?.ToString("yyyy-MM-dd"))</b></div>
                        </div>
                    </div>
                </a>
                <form class="gt7-card-delete-form" method="post" asp-action="DeleteSetup" asp-route-contentItemId="@s.ContentItemId" asp-route-view="@Model.ActiveView" onsubmit="return confirm('Delete this setup permanently? This cannot be undone.');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="gt7-card-delete" title="Delete setup">Delete</button>
                </form>
            </div>
        }
    }
    }

    @* === Rated === *@
    @if (Model.ActiveView == "all" || Model.ActiveView == "rated")
    {
    <div class="gt7-section-title">
        <span>Setups I've rated</span>
        <span class="badge">@Model.Rated.Count</span>
    </div>
    @if (Model.Rated.Count == 0)
    {
        <div class="gt7-empty">You haven't rated any setups yet. <a href="/">Browse setups</a> and click a star.</div>
    }
    else
    {
        @foreach (var s in Model.Rated)
        {
            <div class="gt7-card">
                <a class="gt7-card-link" asp-action="Details" asp-route-contentItemId="@s.ContentItemId">
                    <div class="gt7-card-row">
                        <div class="gt7-card-thumb">
                            @if (s.CarGameId > 0)
                            {
                                <img src="~/GT7TuningShare.Module/car_thumbnails/car@(s.CarGameId).png" alt="" onerror="this.style.display='none'" />
                            }
                        </div>
                        <div class="gt7-card-body">
                            <h2 class="gt7-card-name">@s.Title</h2>
                            <div class="gt7-card-car">@s.CarDisplayText</div>
                        </div>
                        <div class="gt7-card-stars">@(new string('★', s.MyStars))<span style="color:var(--text-faint)">@(new string('☆', 5 - s.MyStars))</span></div>
                        <div class="gt7-card-meta">
                            @if (!string.IsNullOrEmpty(s.Author)) { <div>by @s.Author</div> }
                        </div>
                    </div>
                </a>
                <form class="gt7-card-delete-form" method="post" asp-action="Unrate" asp-route-contentItemId="@s.ContentItemId" asp-route-view="@Model.ActiveView" onsubmit="return confirm('Remove your rating from this setup?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="gt7-card-delete" title="Remove rating">Remove rating</button>
                </form>
            </div>
        }
    }
    }

    @* === Commented === *@
    @if (Model.ActiveView == "all" || Model.ActiveView == "commented")
    {
    <div class="gt7-section-title">
        <span>Setups I've commented on</span>
        <span class="badge">@Model.Commented.Count</span>
    </div>
    @if (Model.Commented.Count == 0)
    {
        <div class="gt7-empty">You haven't commented on any setups yet.</div>
    }
    else
    {
        @foreach (var c in Model.Commented)
        {
            var imgCount = CountCommentImages(c.Body);
            <div class="gt7-comment-card">
                <div class="gt7-comment-card-head">
                    <a asp-action="Details" asp-route-contentItemId="@c.SetupContentItemId">
                        <div class="gt7-card-thumb">
                            @if (c.CarGameId > 0)
                            {
                                <img src="~/GT7TuningShare.Module/car_thumbnails/car@(c.CarGameId).png" alt="" onerror="this.style.display='none'" />
                            }
                        </div>
                        <div class="gt7-card-body">
                            <h2 class="gt7-card-name">@c.SetupTitle</h2>
                            <div class="gt7-card-car">@c.CarDisplayText</div>
                        </div>
                    </a>
                    @if (imgCount > 0)
                    {
                        <span class="gt7-comment-image-badge" title="@imgCount image@(imgCount == 1 ? "" : "s") attached">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                                <polyline points="21 15 16 10 5 21"></polyline>
                            </svg>
                            @imgCount
                        </span>
                    }
                    <form class="gt7-card-delete-form" method="post" asp-action="DeleteComment" asp-route-commentId="@c.CommentId" asp-route-view="@Model.ActiveView" onsubmit="return confirm('Delete this comment?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="gt7-card-delete" title="Delete comment">Delete</button>
                    </form>
                </div>
                <p class="gt7-comment-card-body">@Html.Raw(StripCommentImages(c.Body))</p>
                <div class="gt7-comment-card-date">@c.CreatedUtc.ToString("yyyy-MM-dd HH:mm")</div>
            </div>
        }
    }
    }

</div>

</body>
</html>
